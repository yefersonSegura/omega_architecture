{
  "name": "omega-studio",
  "displayName": "Omega Studio",
  "description": "Integra el CLI Omega (omega_architecture) en el IDE: validate, doctor, init, docs, inspector, generación de ecosistema/agente/flow/app, trazas y flujos IA (coach, redesign) desde la paleta y el explorador.",
  "publisher": "DenisYefersonSeguraFernandez",
  "version": "0.0.24",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yefersonSegura/omega_architecture.git"
  },
  "bugs": {
    "url": "https://github.com/yefersonSegura/omega_architecture/issues"
  },
  "homepage": "https://github.com/yefersonSegura/omega_architecture#readme",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "omega.pickCommand",
        "title": "Ejecutar comando Omega…",
        "category": "Omega"
      },
      {
        "command": "omega.runValidate",
        "title": "Validar omega_setup (validate)",
        "category": "Omega"
      },
      {
        "command": "omega.runDoctor",
        "title": "Doctor del proyecto",
        "category": "Omega"
      },
      {
        "command": "omega.runInit",
        "title": "Init (omega_setup.dart)",
        "category": "Omega"
      },
      {
        "command": "omega.openDoc",
        "title": "Abrir documentación (doc)",
        "category": "Omega"
      },
      {
        "command": "omega.openInspector",
        "title": "Abrir inspector Omega (navegador)",
        "category": "Omega"
      },
      {
        "command": "omega.generateEcosystem",
        "title": "Generar ecosistema (g ecosystem)",
        "category": "Omega"
      },
      {
        "command": "omega.generateAgent",
        "title": "Generar agente (g agent)",
        "category": "Omega"
      },
      {
        "command": "omega.generateFlow",
        "title": "Generar flow (g flow)",
        "category": "Omega"
      },
      {
        "command": "omega.createApp",
        "title": "Crear app Flutter (create app)",
        "category": "Omega"
      },
      {
        "command": "omega.traceView",
        "title": "Trace: ver resumen (trace view)",
        "category": "Omega"
      },
      {
        "command": "omega.traceValidate",
        "title": "Trace: validar (trace validate)",
        "category": "Omega"
      },
      {
        "command": "omega.configureAi",
        "title": "IA: configurar OMEGA_AI_*…",
        "category": "Omega"
      },
      {
        "command": "omega.showAiConfiguration",
        "title": "IA: ver configuración guardada",
        "category": "Omega"
      },
      {
        "command": "omega.runAiDoctor",
        "title": "IA: doctor (ai doctor)",
        "category": "Omega"
      },
      {
        "command": "omega.runAiEnv",
        "title": "IA: variables de entorno (ai env)",
        "category": "Omega"
      },
      {
        "command": "omega.aiExplainTrace",
        "title": "IA: explain trace",
        "category": "Omega"
      },
      {
        "command": "omega.aiCoachStart",
        "title": "IA: coach start",
        "category": "Omega"
      },
      {
        "command": "omega.aiCoachAudit",
        "title": "IA: coach audit",
        "category": "Omega"
      },
      {
        "command": "omega.generateModule",
        "title": "Crear módulo con diseño IA (coach module)",
        "category": "Omega"
      },
      {
        "command": "omega.editUiWithAi",
        "title": "Rediseñar esta pantalla con IA (coach redesign)",
        "category": "Omega"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "omega.editUiWithAi",
          "group": "navigation",
          "when": "resourceExtname == .dart"
        }
      ],
      "explorer/context": [
        {
          "command": "omega.editUiWithAi",
          "group": "omega@1",
          "when": "resourceFilename =~ /.*_page\\.dart/"
        },
        {
          "command": "omega.generateModule",
          "group": "omega@1"
        },
        {
          "command": "omega.pickCommand",
          "group": "omega@0"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "omega-sidebar",
          "title": "Omega",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "omega-sidebar": [
        {
          "id": "omega.sidebarMenu",
          "name": "Comandos",
          "visibility": "visible"
        }
      ]
    },
    "configuration": {
      "title": "Omega Studio",
      "properties": {
        "omegaStudio.ai.injectEnvironment": {
          "type": "boolean",
          "default": true,
          "description": "Si está activado, al ejecutar «omega» desde esta extensión se aplican omegaStudio.ai.* y las claves guardadas en el almacén seguro (OMEGA_AI_*)."
        },
        "omegaStudio.ai.enabled": {
          "type": "boolean",
          "default": false,
          "description": "OMEGA_AI_ENABLED al inyectar el entorno."
        },
        "omegaStudio.ai.provider": {
          "type": "string",
          "enum": [
            "none",
            "openai",
            "gemini",
            "ollama",
            "anthropic"
          ],
          "default": "none",
          "description": "OMEGA_AI_PROVIDER al inyectar el entorno."
        },
        "omegaStudio.ai.model": {
          "type": "string",
          "default": "",
          "description": "OMEGA_AI_MODEL (vacío = no enviar variable)."
        },
        "omegaStudio.ai.baseUrl": {
          "type": "string",
          "default": "",
          "description": "OMEGA_AI_BASE_URL opcional (OpenAI-compatible)."
        }
      }
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "16.x",
    "typescript": "^4.9.5"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  }
}
